# Copia questo file in .env e compila con le tue credenziali Supabase
# Trovi queste variabili in: Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Solo per lo script di seed (NON esposta al frontend — niente VITE_ prefix)
# Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Generazione sinossi automatica (solo server-side — NON usare VITE_ prefix)
# Anthropic Console → API Keys: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare Worker per storyboard YouTube (opzionale — migliora la copertura visiva)
# Deploy: cf-worker/index.js su Cloudflare Dashboard → Workers & Pages
CF_STORYBOARD_WORKER_URL=https://yt-storyboard.tuonome.workers.dev

# YouTube Data API v3 (opzionale — aggiunge la descrizione testuale del video)
# Google Cloud Console → APIs → YouTube Data API v3 → Credentials
YOUTUBE_API_KEY=AIza...
