# Copia questo file in .env e compila con le tue credenziali

# Supabase — Dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anthropic — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ScraperAPI — scraperapi.com → Dashboard (piano free: 5000 crediti)
SCRAPER_API_KEY=your-scraper-api-key

# Groq Whisper — console.groq.com → API Keys (gratuito)
GROQ_API_KEY=gsk_...

# NAS MODO2 — server yt-dlp sul NAS Synology in ufficio
NAS_URL=http://steadytube-nas.synology.me:3100
NAS_SECRET=your-nas-secret
